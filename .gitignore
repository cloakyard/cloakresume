# ── macOS ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
# Note: don't add `Icon?` here — `?` is a glob wildcard, and combined
# with core.ignorecase=true (the default on macOS) it matches the
# `icons/` directory and silently hides every asset inside.
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

